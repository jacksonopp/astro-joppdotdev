---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/astro/Hero.astro";

import ThreeColumn from "../layouts/ThreeColumn.astro";
// import computerPng from "../images/computer.png";
// import pearsonLogo from "../images/pearson-logo.png";
// import sdgLogo from "../images/sdg_Logo-1.png";
// import onvueLogo from "../images/onvue-logo-color.png";
// import virtuwellLogo from "../images/virtuwell-nohp.png";
// import hpLogo from "../images/hp-logo.png";
import SectionTitle from "../components/svelte/SectionTitle.svelte";
import Contact from "../components/astro/Contact.astro";
import CldImage from "../components/astro/CldImage.astro";

const hero = await getEntry("hero", "hompage");
if (!hero) throw new Error("Homepage hero content not found");
---

<Layout title="Jackson Oppenheim, UX Developer">
  <main>
    <Hero heroContent={hero} cta twoColumns={true} />

    <ThreeColumn title="About Me" id="about-me">
      <div slot="col1" class="prose prose-slate">
        <h3 class="font-display mb-[0.5em] text-3xl font-bold text-dark-900">
          Five Years of Building for Real Users
        </h3>
        <p>
          I've spent the last five years working across healthcare,
          e-commerce, and education — three industries where a confusing
          interface has real consequences, not just a bad review. That's
          shaped how I think about UX: less about surface polish, more about
          whether someone can actually get what they came for.
        </p>
      </div>

      <CldImage
        class="rounded-2xl shadow-card"
        src="portfolio/images/IMG_1630_ahx0ak"
        width={400}
        alt="alt"
        slot="col2"
        fit="thumb"
        zoom="0.2"
        ratio={[4, 3]}
        gravity="face"
      />
      <div slot="col3" class="prose">
        <p>
          I stay close to how people actually use the products I build —
          through research, testing, and just paying attention to where
          things break down — rather than relying on trends or best-practice
          checklists alone.
        </p>
        <p>
          The best interfaces I've worked on came out of close collaboration
          with designers, engineers, and stakeholders, not from any one
          person working in isolation. I try to be the one on the team who
          keeps that conversation grounded in what users actually need.
        </p>
      </div>
    </ThreeColumn>
    <section aria-label="companies" class="border-y border-dark-100 bg-dark-50">
      <div class="mx-auto max-w-6xl px-8 pt-12 md:px-16">
        <SectionTitle>Companies I've Worked With</SectionTitle>
      </div>
      <div
        class="mx-auto flex max-w-6xl flex-wrap items-center justify-evenly gap-x-12 gap-y-8 px-8 pb-12 pt-4 lg:flex-row lg:px-16 lg:pb-16"
      >
        <CldImage
          class="opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
          src="portfolio/logos/pearson-logo"
          height={60}
          alt="alt"
          fit="fit"
        />
        <CldImage
          class="opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
          src="portfolio/logos/onvue-logo-color"
          height={60}
          alt="alt"
          fit="fit"
        />
        <CldImage
          class="opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
          src="portfolio/logos/sdg-logo"
          height={60}
          alt="alt"
          fit="fit"
        />
        <CldImage
          class="opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
          src="portfolio/logos/osn_logo_mdmftc"
          height={60}
          alt="alt"
          fit="fit"
        />
        <CldImage
          class="opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
          src="portfolio/logos/new_vw_logo_scgdnb"
          height={60}
          alt="alt"
          fit="fit"
        />
        <CldImage
          class="opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0"
          src="portfolio/logos/hp-logo_rtwde9"
          height={60}
          alt="alt"
          fit="fit"
        />
      </div>
    </section>
    <section class="mx-auto max-w-4xl px-8 py-16 md:px-16 md:py-24" aria-labelledby="contact">
      <SectionTitle id="contact">Contact Me</SectionTitle>
      <Contact />
    </section>
  </main>
</Layout>
