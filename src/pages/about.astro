---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/astro/Hero.astro";
import SectionTitle from "../components/svelte/SectionTitle.svelte";

import ContactSection from "../components/astro/ContactSection.astro";
import CldImage from "../components/astro/CldImage.astro";

const about = await getEntry("about", "about");
if (!about) throw new Error("About content not found");
const { Content: AboutContent } = await render(about);

const aboutHero = await getEntry("hero", "about");
if (!aboutHero) throw new Error("About hero content not found");

const capabilities = [
  {
    title: "Information Architecture",
    img: "portfolio/illustrations/ui-sketch_lzpzxg",
    alt: "A ui",
    description:
      "Turning a pile of content and features into something users can actually navigate — through site maps, wireframes, and the documentation that keeps a team aligned as it evolves.",
  },
  {
    title: "Front-end Development",
    img: "portfolio/illustrations/3char_ymzpci",
    alt: "Three people collaborating",
    description:
      "Turning a design into a real, working interface — one that holds up in the browser as well as it does in the mockup.",
  },
  {
    title: "Accessibility Testing",
    img: "portfolio/illustrations/wheelchair_xemzqd",
    alt: "Three people collaborating",
    description:
      "Testing against WCAG 2.1 and real assistive technology to catch what a visual review misses, so the product works for people of all abilities, not just the average case.",
  },
];
---

<Layout title="About | Jackson Oppenheim">
  <Hero heroContent={aboutHero} />
  <main class="mx-auto max-w-6xl px-8 py-16 md:py-24">
    <article class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <figure class="m-0 lg:sticky lg:top-28 lg:self-start">
        <CldImage
          class="w-full rounded-2xl shadow-card"
          src="portfolio/images/IMG_1647_dhrfc1"
          alt="Jackson sitting with a glass of wine"
          widths={[400, 600]}
          medias={["(max-width: 1000px)"]}
          ratio={[4, 5]}
        />
        <figcaption class="mt-3 text-sm text-dark-500">
          I've been also known to enjoy a glass of wine.
        </figcaption>
      </figure>
      <div
        class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-dark-900 prose-a:text-primary-700"
      >
        <AboutContent />
      </div>
    </article>
  </main>
  <section class="border-y border-dark-100 bg-dark-50">
    <div class="mx-auto max-w-6xl px-8 py-16 lg:px-16 lg:py-24">
      <div class="grid gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:gap-16">
        <div class="lg:sticky lg:top-28 lg:self-start">
          <SectionTitle>What I Can Do For You</SectionTitle>
          <p class="max-w-sm text-lg text-dark-600">
            A few of the ways I can help, depending on where your project is
            at.
          </p>
        </div>
        <ol class="grid gap-8">
          {
            capabilities.map((item, i) => (
              <li class="flex flex-wrap items-center gap-6 border-t border-dark-200/70 pt-8 first:border-t-0 first:pt-0 sm:flex-nowrap">
                <span class="font-display text-3xl font-bold text-primary-200">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <CldImage
                  class="h-16 w-16 shrink-0 rounded-xl bg-white object-contain p-2 shadow-soft sm:h-20 sm:w-20"
                  src={item.img}
                  alt={item.alt}
                  height={80}
                />
                <div class="min-w-[16rem] flex-1">
                  <h3 class="font-display text-xl font-bold text-dark-900">
                    {item.title}
                  </h3>
                  <p class="mt-2 text-dark-600">{item.description}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-8 py-16 md:px-16 md:py-24">
    <ContactSection heading="Let's talk about your project." />
  </section>
</Layout>
