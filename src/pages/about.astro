---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/astro/Hero.astro";
import SectionTitle from "../components/svelte/SectionTitle.svelte";

import Contact from "../components/astro/Contact.astro";
import CldImage from "../components/astro/CldImage.astro";

const about = await getEntry("about", "about");
if (!about) throw new Error("About content not found");
const { Content: AboutContent } = await render(about);

const aboutHero = await getEntry("hero", "about");
if (!aboutHero) throw new Error("About hero content not found");
---

<Layout title="About | Jackson Oppenheim">
  <Hero heroContent={aboutHero} />
  <main class="px-8">
    <article
      class="mx-auto flex max-w-6xl flex-col-reverse items-center justify-center gap-12 py-16 md:px-0 md:py-24 lg:flex-row"
    >
      <div class="prose prose-headings:font-display prose-headings:text-dark-900 prose-a:text-primary-700">
        <AboutContent />
      </div>
      <figure class="m-0 shrink-0">
        <CldImage
          class="w-64 rounded-2xl shadow-card md:w-80"
          src="portfolio/images/IMG_1647_dhrfc1"
          alt="Jackson sitting with a glass of wine"
          widths={[200, 400]}
          medias={["(max-width): 1000px"]}
          ratio={[1, 1]}
        />
        <figcaption class="mt-3 text-center text-sm text-dark-500">
          I've been also known to enjoy a glass of wine.
        </figcaption>
      </figure>
    </article>
  </main>
  <section class="border-y border-dark-100 bg-dark-50">
    <div class="mx-auto max-w-6xl px-8 py-16 lg:px-16 lg:py-24">
      <SectionTitle>What I Can Do For You</SectionTitle>
      <p class="max-w-2xl text-lg text-dark-600">
        A few of the ways I can help, depending on where your project is at.
      </p>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div
          class="flex flex-col items-center gap-4 rounded-2xl bg-white p-8 text-center shadow-soft"
        >
          <CldImage
            src="portfolio/illustrations/ui-sketch_lzpzxg"
            alt="A ui"
            height={140}
          />
          <h3 class="font-display text-xl font-bold text-dark-900">
            Information Architecture
          </h3>
          <p class="text-dark-600">
            Turning a pile of content and features into something users can
            actually navigate — through site maps, wireframes, and the
            documentation that keeps a team aligned as it evolves.
          </p>
        </div>
        <div
          class="flex flex-col items-center gap-4 rounded-2xl bg-white p-8 text-center shadow-soft"
        >
          <CldImage
            src="portfolio/illustrations/3char_ymzpci"
            alt="Three people collaborating"
            height={140}
          />
          <h3 class="font-display text-xl font-bold text-dark-900">
            Front-end Development
          </h3>
          <p class="text-dark-600">
            Turning a design into a real, working interface — one that holds
            up in the browser as well as it does in the mockup.
          </p>
        </div>
        <div
          class="flex flex-col items-center gap-4 rounded-2xl bg-white p-8 text-center shadow-soft"
        >
          <CldImage
            src="portfolio/illustrations/wheelchair_xemzqd"
            alt="Three people collaborating"
            height={140}
          />
          <h3 class="font-display text-xl font-bold text-dark-900">
            Accessibility Testing
          </h3>
          <p class="text-dark-600">
            Testing against WCAG 2.1 and real assistive technology to catch
            what a visual review misses, so the product works for people of
            all abilities, not just the average case.
          </p>
        </div>
      </div>
    </div>
  </section>
  <section class="mx-auto max-w-4xl px-8 py-16 md:px-16 md:py-24">
    <SectionTitle>Contact me</SectionTitle>

    <Contact />
  </section>
</Layout>
