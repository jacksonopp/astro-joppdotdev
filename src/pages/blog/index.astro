---
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/astro/PostCard.astro";

type MarkdownPost = {
  frontmatter: {
    image: string;
    summary: string;
    title: string;
    date: {
      published: string;
    };
  };
  url: string;
};

let posts = Object.values(import.meta.glob<MarkdownPost>("./*.md", { eager: true }));

posts = posts.sort((a, b) =>
  new Date(a.frontmatter.date.published) >
  new Date(b.frontmatter.date.published)
    ? -1
    : 1
);
---

<Layout title="Blog | Jackson Oppenheim" noindex>
  <div class="mx-auto grid max-w-6xl gap-6 px-8 py-16 sm:grid-cols-2 md:px-16 md:py-24 lg:grid-cols-3">
    {
      posts.map((post) => (
        <PostCard
          img={post.frontmatter.image}
          path={post.url}
          summary={post.frontmatter.summary}
          title={post.frontmatter.title}
          published={post.frontmatter.date.published}
        />
      ))
    }
  </div>
</Layout>
