---
import { Icon } from "astro-icon/components";
import SectionTitle from "../svelte/SectionTitle.svelte";
import Contact from "./Contact.astro";

interface Props {
  heading?: string;
  description?: string;
}

const {
  heading = "Let's build something that works.",
  description = "Tell me a bit about your project and I'll get back to you within a day or two.",
} = Astro.props;
---

<div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
  <div>
    <SectionTitle id="contact">Contact Me</SectionTitle>
    <h3 class="font-display mb-4 text-3xl font-bold text-dark-900 md:text-4xl">
      {heading}
    </h3>
    <p class="max-w-sm text-dark-600">{description}</p>

    <ul class="mt-8 flex flex-col gap-4">
      <li class="flex items-center gap-3">
        <span
          class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-primary-50 text-primary-700"
        >
          <Icon name="mdi:phone-outline" />
        </span>
        <a
          class="font-semibold text-dark-800 transition-colors hover:text-primary-700"
          href="tel:+14406656551">440.665.6551</a
        >
      </li>
      <li class="flex items-center gap-3">
        <span
          class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-primary-50 text-primary-700"
        >
          <Icon name="mdi:email-outline" />
        </span>
        <a
          class="font-semibold text-dark-800 transition-colors hover:text-primary-700"
          href="mailto:me@jopp.dev">me@jopp.dev</a
        >
      </li>
    </ul>

    <div class="mt-8 flex gap-3">
      <a
        href="https://www.linkedin.com/in/jacksonopp/"
        target="_blank"
        aria-label="LinkedIn"
        class="grid h-10 w-10 place-items-center rounded-full border border-dark-200 text-dark-600 transition-colors hover:border-primary-400 hover:text-primary-700"
      >
        <Icon name="mdi:linkedin" />
        <span class="sr-only">Linkedin</span>
      </a>
      <a
        href="https://github.com/jacksonopp"
        target="_blank"
        aria-label="GitHub"
        class="grid h-10 w-10 place-items-center rounded-full border border-dark-200 text-dark-600 transition-colors hover:border-primary-400 hover:text-primary-700"
      >
        <Icon name="mdi:github" />
        <span class="sr-only">Github</span>
      </a>
    </div>
  </div>

  <div class="rounded-2xl border border-dark-100 bg-white p-6 shadow-card md:p-8">
    <Contact />
  </div>
</div>

<style>
  [astro-icon] {
    @apply h-5 w-5;
  }
</style>
