---
import { Icon } from "astro-icon/components";

interface Props {
  label?: string;
  icon?: string;
  class?: string;
}

const {
  label = "Screenshot coming soon",
  icon = "ph:image-duotone",
  class: className = "",
} = Astro.props;
---

<div
  class={`relative flex aspect-[4/3] w-full items-center justify-center overflow-hidden rounded-lg bg-gradient-to-br from-primary-700 via-primary-600 to-accent-500 ${className}`}
>
  <div class="flex flex-col items-center gap-3 px-6 text-center text-white/90">
    <Icon name={icon} class="h-10 w-10" />
    <p class="font-display text-sm font-semibold tracking-wide">{label}</p>
  </div>
</div>
