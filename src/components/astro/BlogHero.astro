---
import CldImage from "./CldImage.astro";

interface Props {
  img: {
    path: string;
    alt: string;
    credit: string;
  };
  title: string;
  summary: string;
}

const { img, title, summary } = Astro.props;
---

<section class="relative overflow-hidden bg-primary-950 px-8 py-16 text-white md:px-16 md:py-20">
  <div
    class="pointer-events-none absolute -top-32 -right-16 h-72 w-72 rounded-full bg-accent-500/25 blur-[100px]"
  >
  </div>
  <div
    class="relative mx-auto grid max-w-5xl items-center gap-10 md:grid-cols-2"
  >
    <div>
      <h1 class="font-display text-3xl font-bold leading-tight md:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-primary-100/90">{summary}</p>
    </div>
    <CldImage
      class="aspect-video w-full rounded-2xl object-cover shadow-card"
      src={img.path}
      alt={img.alt}
      widths={[400, 600, 800]}
      ratio={[16, 9]}
      medias={["(max-width: 768px)", "(max-width: 1024px)"]}
    />
  </div>
</section>
