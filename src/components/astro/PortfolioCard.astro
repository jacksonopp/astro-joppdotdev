---
import { Icon } from "astro-icon/components";
import CldImage from "./CldImage.astro";

interface Props {
  imgUrl: string;
  alt: string;
  title: string;
  href: string;
  class?: string;
  imgClass?: string;
}

const {
  imgUrl,
  alt,
  title,
  href,
  class: className = "",
  imgClass = "aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105",
} = Astro.props;
---

<a
  href={href}
  class={`group relative block h-full overflow-hidden rounded-2xl bg-dark-100 shadow-soft transition-shadow duration-300 hover:shadow-card-hover ${className}`}
>
  <CldImage
    class={imgClass}
    src={imgUrl}
    alt={alt}
    widths={[400, 800]}
    ratio={[4, 3]}
    medias={["(max-width: 768px)", "(max-width: 1024px)"]}
    fit="fill"
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-dark-950/85 via-dark-950/10 to-transparent"
  >
  </div>
  <div
    class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-3 p-5"
  >
    <p class="font-display text-lg font-semibold text-white">{title}</p>
    <span
      class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-white/15 text-white backdrop-blur-sm transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:bg-accent-500"
    >
      <Icon name="ph:arrow-up-right-bold" />
    </span>
  </div>
</a>
