---
interface Props {
  omitCurrentPage?: boolean;
}

const { omitCurrentPage } = Astro.props;

const paths = Astro.url.pathname.split("/");
paths.shift();
if (omitCurrentPage) {
  paths.pop();
}
const pathLinks = paths.map((path, i) => {
  return {
    name: path.split("-").join(" ").toLowerCase(),
    url: `/${paths.slice(0, i + 1).join("/")}`,
  };
});
---

<nav
  aria-label="breadcrumbs"
  class="flex flex-wrap items-center justify-center gap-1.5 text-sm text-dark-500 md:justify-start"
>
  <a href="/" class="transition-colors hover:text-primary-700">home</a>
  {
    pathLinks.map((path) => (
      <>
        <span class="text-dark-300">/</span>
        <a href={path.url} class="transition-colors hover:text-primary-700">
          {path.name}
        </a>
      </>
    ))
  }
</nav>
