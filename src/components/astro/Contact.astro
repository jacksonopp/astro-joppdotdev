---
import { type ZodError, z } from "astro/zod";
import CountableTextArea from "../svelte/CountableTextArea.svelte";

const siteKey = import.meta.env.PUBLIC_SITE_KEY;

interface Props {
  dark?: boolean;
}

const { dark } = Astro.props;

type Errors = {
  name?: string[];
  email?: string[];
  phone?: string[];
  message?: string[];
};

let hasErrors = false;

let errors: Errors = {
  name: [],
  email: [],
  phone: [],
  message: [],
};

// /^\d{10}$/

const contactSchema = z.object({
  name: z
    .string({ required_error: "Name is required" })
    .min(2, { message: "Name must be at least 2 characters" }),
  email: z.string({ required_error: "Email is required" }).email(),
  phone: z.string({ required_error: "Phone number is required" }),
  message: z
    .string({ required_error: "Message is required" })
    .max(1000, { message: "Message must be fewer than 1000 characters" }),
});

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  // Honeypot: real visitors never see or fill this field, so a filled-in
  // value means the submission came from a bot. Drop it silently rather
  // than surfacing an error, so the bot has no signal that it was caught.
  const honeypot = data.get("company");

  if (!honeypot) {
    try {
      const formData = contactSchema.parse(Object.fromEntries(data));
      const headers = new Headers();
      headers.append("Content-Type", "application/json");
      console.log(formData);
      fetch("https://eoiv8u9dtix4tl1.m.pipedream.net", {
        method: "POST",
        headers,
        mode: "cors",
        body: JSON.stringify(formData),
      });
    } catch (error) {
      hasErrors = true;
      const e = error as ZodError;
      errors = e.flatten<Errors>().fieldErrors;
      console.error(errors);
    }
  }
}
---

{
  hasErrors && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4 text-red-800 shadow-soft">
      <p class="font-semibold">Please correct the following errors:</p>
      <ul class="mt-1 list-inside list-disc">
        {errors.name?.map((err) => (
          <li>{err}</li>
        ))}
        {errors.email?.map((err) => (
          <li>{err}</li>
        ))}
        {errors.phone?.map((err) => (
          <li>{err}</li>
        ))}
        {errors.message?.map((err) => (
          <li>{err}</li>
        ))}
      </ul>
    </div>
  )
}
<form
  class="grid gap-x-6 gap-y-6 sm:grid-cols-2"
  method="post"
  id="contact-form"
>
  <div
    class="absolute left-[-9999px] top-auto h-0 w-0 overflow-hidden opacity-0"
    aria-hidden="true"
  >
    <label for="company">Company</label>
    <input
      type="text"
      name="company"
      id="company"
      tabindex="-1"
      autocomplete="off"
    />
  </div>
  <div class="grid gap-2">
    <label
      for="name"
      class="text-xs font-bold uppercase tracking-wide text-dark-500 after:ml-0.5 after:text-accent-500 after:content-[attr(data-after)]"
      data-after="*">Name</label
    >
    <input
      required
      type="text"
      name="name"
      id="name"
      class="rounded-xl border border-dark-200 bg-white p-3 text-dark-900 placeholder:text-dark-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 invalid:required:border-dark-200 invalid:required:ring-0"
      placeholder="me@example.com"
    />
  </div>
  <div class="grid gap-2">
    <label
      for="email"
      class="text-xs font-bold uppercase tracking-wide text-dark-500 after:ml-0.5 after:text-accent-500 after:content-[attr(data-after)]"
      data-after="*">Email</label
    >
    <input
      required
      type="email"
      name="email"
      id="email"
      class="rounded-xl border border-dark-200 bg-white p-3 text-dark-900 placeholder:text-dark-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 invalid:required:border-dark-200 invalid:required:ring-0"
      placeholder="me@example.com"
    />
  </div>
  <div class="grid gap-2 sm:col-span-2">
    <label
      for="phone"
      class="text-xs font-bold uppercase tracking-wide text-dark-500 after:ml-0.5 after:text-accent-500 after:content-[attr(data-after)]"
      data-after="*">Phone (555-555-5555)</label
    >
    <input
      required
      type="tel"
      name="phone"
      id="phone"
      class="w-full rounded-xl border border-dark-200 bg-white p-3 text-dark-900 placeholder:text-dark-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 invalid:required:border-dark-200 invalid:required:ring-0"
      placeholder="555-555-5555"
    />
  </div>
  <div class="grid gap-2 sm:col-span-2">
    <label
      for="message"
      class="text-xs font-bold uppercase tracking-wide text-dark-500 after:ml-0.5 after:text-accent-500 after:content-[attr(data-after)]"
      data-after="*">Message</label
    >
    <CountableTextArea
      client:load
      required
      name="message"
      id="message"
      className="w-full rounded-xl border border-dark-200 bg-white p-3 text-dark-900 placeholder:text-dark-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30"
      placeholder="Your message goes here"
    />
  </div>
  <button
    class="g-recaptcha inline-flex w-fit items-center justify-center gap-2 rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold tracking-wide text-white shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-600 hover:shadow-card"
    data-sitekey={siteKey}
    data-callback="onSubmit">Send Message</button
  >

  <script async src="https://www.google.com/recaptcha/api.js"></script>

  <script is:inline>
    const formEl = document.getElementById("contact-form");
    formEl.addEventListener("submit", (e) => {
      e.preventDefault();
    });

    async function onSubmit(token) {
      console.log("validating...");
      const res = await fetch("/api/recaptcha", {
        method: "POST",
        body: JSON.stringify(token),
      });
      const gRes = await res.json();
      if (gRes.responseData.success) {
        formEl.submit();
      } else {
        console.log("Validation failed for some reason?");
      }
    }
  </script>
</form>
