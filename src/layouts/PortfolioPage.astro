---
import BreadCrumbs from "../components/astro/BreadCrumbs.astro";
import CldImage from "../components/astro/CldImage.astro";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | Jackson Oppenheim`}>
  <div class="mx-auto max-w-4xl px-8 pt-8 md:px-0">
    <BreadCrumbs />
  </div>
  <!-- Article -->
  <article
    class="prose prose-lg mx-auto max-w-lg py-12 px-8 prose-headings:font-display prose-headings:text-dark-900 prose-a:text-primary-700 prose-blockquote:border-accent-500 prose-img:rounded-2xl prose-img:shadow-card md:max-w-xl md:px-0 lg:max-w-2xl xl:max-w-4xl"
  >
    <slot />
  </article>
</Layout>
